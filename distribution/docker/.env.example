GARAGEBALANCE_VERSION=__GARAGEBALANCE_VERSION__
POSTGRES_DB=garagebalance
POSTGRES_USER=garagebalance
POSTGRES_PASSWORD=__GENERATE__
JWT_SIGNING_KEY=__GENERATE__
DATA_PROTECTION_KEYS_PATH=/var/lib/garagebalance/keys
ASPNETCORE_ENVIRONMENT=Production
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
API_BIND_ADDRESS=127.0.0.1
API_PORT=5080
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://127.0.0.1:5173
BACKUP_HOST_PATH=./backups
APPLY_MIGRATIONS_ON_STARTUP=true
REQUIRE_PRE_MIGRATION_BACKUP=true
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_AUTOMATIC_ENABLED=true
DATABASE_BACKUP_INTERVAL_HOURS=24
DATABASE_BACKUP_RETENTION_COUNT=30
LOG_HOST_PATH=./logs
DIAGNOSTIC_LOGGING_ENABLED=true
DIAGNOSTIC_LOGGING_RETENTION_DAYS=14
DIAGNOSTIC_LOGGING_MAX_FILE_SIZE_MB=10
DIAGNOSTIC_PACKAGE_DAYS=7
DIAGNOSTIC_PACKAGE_MAX_SIZE_MB=20
